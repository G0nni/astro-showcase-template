      <Code
        code={`{\n  type: "features",\n  style: {\n    background: "dark",         // "white" | "light" | "dark" | "primary" | "gradient"\n    padding: "lg",              // "sm" | "md" | "lg" — défaut: "md"\n    align: "left",              // "left" | "center" — défaut: "center"\n    backgroundImage: "https://example.com/photo.jpg", // image de fond (overlay sombre auto)\n  },\n  props: { ... },\n}`}
        lang="ts"
        theme="github-dark"
        class="rounded-xl overflow-hidden mb-5"
      />
      <div class="bg-amber-50 border border-amber-100 rounded-xl p-4 text-sm text-amber-800 mb-5">
        <strong>Couleur primaire globale :</strong> changez <code class="bg-white/60 px-1 rounded">global.brandColor</code> dans <code class="bg-white/60 px-1 rounded">site.ts</code> pour personnaliser la couleur de toutes les sections <code class="bg-white/60 px-1 rounded">primary</code>, les boutons et les accents d'un seul coup.
        <Code code={`global: {\n  name: "Mon Site",\n  brandColor: "#7c3aed", // ← violet au lieu du bleu par défaut\n}`} lang="ts" theme="github-light" class="rounded-lg overflow-hidden mt-3 text-xs" />
      </div>
      <div class="grid grid-cols-5 gap-2 text-center text-xs">
        {[
          { name: 'white', bg: 'bg-white border border-gray-200', text: 'text-gray-700' },
          { name: 'light', bg: 'bg-gray-100', text: 'text-gray-700' },
          { name: 'dark', bg: 'bg-gray-900', text: 'text-white' },
          { name: 'primary', bg: 'bg-blue-600', text: 'text-white' },
          { name: 'gradient', bg: 'bg-gradient-to-br from-blue-600 to-purple-700', text: 'text-white' },
        ].map(s => (
          <div class={`${s.bg} rounded-xl py-4 px-2`}>
            <span class={`font-mono font-semibold ${s.text}`}>{s.name}</span>
