---
import type { CtaBlock } from '../../types/site';

type Props = CtaBlock['props'];

const { title, subtitle, cta } = Astro.props;
---

<section class="bg-gray-900 py-24">
  <div class="max-w-3xl mx-auto px-6 text-center">

    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
      {title}
    </h2>

    <p class="text-gray-400 text-lg leading-relaxed mb-10">
      {subtitle}
    </p>

    <a
      href={cta.href}
      class="inline-flex items-center justify-center px-7 py-3.5 bg-white text-gray-900 font-semibold rounded-xl hover:bg-gray-100 transition-colors text-sm"
    >
      {cta.label}
    </a>

  </div>
</section>
