---
import DocsLayout from '../layouts/DocsLayout.astro';
import { Code } from 'astro:components';
import SectionRenderer from '../components/SectionRenderer.astro';
import type { SectionBlock } from '../types/site';

const nav = [
  {
    title: 'Démarrage',
    items: [
      { label: 'Introduction', href: '#introduction' },
      { label: 'Prérequis', href: '#prerequis' },
      { label: 'Installation', href: '#installation' },
    ],
  },
  {
    title: 'Modifier votre site',
    items: [
      { label: 'Structure du projet', href: '#structure' },
      { label: 'Éditer site.ts', href: '#editer' },
      { label: 'Créer une page', href: '#nouvelle-page' },
      { label: 'Styles', href: '#styles' },
    ],
  },
  {
    title: 'Sections disponibles',
    items: [
      { label: 'hero', href: '#section-hero', code: true },
      { label: 'features', href: '#section-features', code: true },
      { label: 'stats', href: '#section-stats', code: true },
      { label: 'cta', href: '#section-cta', code: true },
      { label: 'text', href: '#section-text', code: true },
      { label: 'testimonials', href: '#section-testimonials', code: true },
      { label: 'imageText', href: '#section-imagetext', code: true },
      { label: 'faq', href: '#section-faq', code: true },
      { label: 'contactInfo', href: '#section-contactinfo', code: true },
      { label: 'logos', href: '#section-logos', code: true },
      { label: 'pricing', href: '#section-pricing', code: true },
      { label: 'steps', href: '#section-steps', code: true },
      { label: 'team', href: '#section-team', code: true },
      { label: 'timeline', href: '#section-timeline', code: true },
      { label: 'video', href: '#section-video', code: true },
      { label: 'gallery', href: '#section-gallery', code: true },
      { label: 'newsletter', href: '#section-newsletter', code: true },
      { label: 'comparison', href: '#section-comparison', code: true },
      { label: 'download', href: '#section-download', code: true },
      { label: 'map', href: '#section-map', code: true },
      { label: 'reviews', href: '#section-reviews', code: true },
    ],
  },
  {
    title: 'Options globales',
    items: [
      { label: 'banner', href: '#option-banner' },
      { label: 'header.variant', href: '#option-header' },
      { label: 'roundedCards', href: '#option-rounded' },
      { label: 'animation: fade', href: '#option-animation' },
      { label: 'className', href: '#option-classname' },
    ],
  },
  {
    title: 'Avancé',
    items: [
      { label: 'Templates de départ', href: '#templates' },
      { label: 'Utiliser avec une IA', href: '#ia' },
      { label: 'Déploiement', href: '#deploiement' },
    ],
  },
];

// Section demos
const heroDemo: SectionBlock = {
