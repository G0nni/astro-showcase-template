---
import type { FeaturesBlock, SectionStyle } from '../../types/site';
import SectionWrapper from './SectionWrapper.astro';

type Props = FeaturesBlock['props'] & { style?: SectionStyle };

const { title, items, style } = Astro.props;

const isDark = style?.background && ['dark', 'primary', 'gradient'].includes(style.background);
const headingClass = isDark ? 'text-white' : 'text-gray-900';
const cardClass = isDark
  ? 'p-8 border border-white/10 rounded-2xl bg-white/5'
  : 'p-8 border border-gray-100 rounded-2xl hover:shadow-lg hover:border-gray-200 transition-all duration-200 bg-white';
const cardTitleClass = isDark ? 'text-white' : 'text-gray-900';
const cardDescClass = isDark ? 'text-white/70' : 'text-gray-500';
---

<SectionWrapper style={style}>
  <h2 class={`text-3xl md:text-4xl font-bold text-center ${headingClass} mb-16`}>
    {title}
  </h2>

  <div class="grid md:grid-cols-3 gap-8">
    {items.map((item: { title: string; description: string }) => (
      <div class={cardClass}>
        <h3 class={`text-xl font-semibold ${cardTitleClass} mb-3`}>{item.title}</h3>
        <p class={`${cardDescClass} leading-relaxed`}>{item.description}</p>
      </div>
    ))}
  </div>
</SectionWrapper>
