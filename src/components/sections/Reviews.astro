---
import type { ReviewsBlock, SectionStyle } from '../../types/site';
import SectionWrapper from './SectionWrapper.astro';

type Props = ReviewsBlock['props'] & { style?: SectionStyle };

const { title, items, style } = Astro.props;

const isDark = style?.background && ['dark', 'primary', 'gradient'].includes(style.background);
const headingClass = isDark ? 'text-white' : 'text-gray-900';
const cardClass    = isDark ? 'bg-white/5 border border-white/10' : 'bg-white border border-gray-100 shadow-sm';
const sourceClass  = isDark ? 'text-white font-semibold' : 'text-gray-900 font-semibold';
const countClass   = isDark ? 'text-white/50' : 'text-gray-400';
---

<SectionWrapper style={style ?? { background: 'light', padding: 'md' }}>
  {title && (
    <h2 class={`text-2xl md:text-3xl font-bold text-center ${headingClass} mb-10`}>{title}</h2>
  )}

  <div class={`flex flex-wrap justify-center gap-6`}>
    {items.map((item: import('../../types/site').ReviewSourceItem) => {
      const max = item.maxRating ?? 5;
      const fullStars = Math.floor(item.rating);
      const hasHalf = item.rating - fullStars >= 0.5;
      const emptyStars = max - fullStars - (hasHalf ? 1 : 0);

      return (
        <a
          href={item.link ?? '#'}
          target={item.link ? '_blank' : undefined}
          rel={item.link ? 'noopener noreferrer' : undefined}
          class={`flex flex-col items-center gap-3 p-6 rounded-card min-w-40 ${cardClass} ${item.link ? 'hover:shadow-md transition-shadow' : ''}`}
        >
          {item.logoUrl ? (
            <img src={item.logoUrl} alt={item.source} class="h-7 w-auto object-contain" loading="lazy" />
          ) : (
            <p class={`text-sm font-bold ${sourceClass}`}>{item.source}</p>
          )}

          <div class="flex items-center gap-0.5">
            {Array.from({ length: fullStars }).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            {hasHalf && (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <defs>
                  <linearGradient id="half">
                    <stop offset="50%" stop-color="currentColor" />
                    <stop offset="50%" stop-color="transparent" />
                  </linearGradient>
                </defs>
                <path fill="url(#half)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            )}
            {Array.from({ length: emptyStars }).map(() => (
              <svg class="w-5 h-5 text-gray-200" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <div class="text-center">
            <p class={`text-2xl font-extrabold ${sourceClass}`}>{item.rating.toFixed(1)}<span class={`text-sm font-normal ${countClass}`}>/{max}</span></p>
            {item.reviewCount && <p class={`text-xs mt-0.5 ${countClass}`}>{item.reviewCount.toLocaleString('fr-FR')} avis</p>}
            {item.logoUrl && <p class={`text-xs mt-1 ${countClass}`}>{item.source}</p>}
          </div>
        </a>
      );
    })}
  </div>
</SectionWrapper>
