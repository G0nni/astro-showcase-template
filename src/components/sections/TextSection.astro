---
import type { TextBlock } from '../../types/site';

type Props = TextBlock['props'];

const { title, paragraphs } = Astro.props;
---

<section class="py-24 bg-white">
  <div class="max-w-3xl mx-auto px-6">

    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-12 leading-tight">
      {title}
    </h1>

    <div class="space-y-6">
      {paragraphs.map((paragraph) => (
        <p class="text-lg text-gray-600 leading-relaxed">{paragraph}</p>
      ))}
    </div>

  </div>
</section>
