---
import type { PricingBlock, SectionStyle } from '../../types/site';
import SectionWrapper from './SectionWrapper.astro';

type Props = PricingBlock['props'] & { style?: SectionStyle };

const { title, plans, style } = Astro.props;

const isDark = style?.background && ['dark', 'primary', 'gradient'].includes(style.background);
const headingClass = isDark ? 'text-white' : 'text-gray-900';
---

<SectionWrapper style={style}>
  {title && (
    <h2 class={`text-3xl md:text-4xl font-bold text-center ${headingClass} mb-16`}>{title}</h2>
  )}

  <div class={`grid gap-8 ${plans.length === 2 ? 'md:grid-cols-2 max-w-3xl mx-auto' : 'md:grid-cols-3'}`}>
    {plans.map((plan: import('../../types/site').PricingPlan) => (
      <div class={`relative flex flex-col rounded-2xl p-8 ${
        plan.highlighted
          ? 'bg-[var(--color-brand,#2563eb)] text-white ring-2 ring-[var(--color-brand,#2563eb)] ring-offset-2'
          : isDark
            ? 'bg-white/5 border border-white/10'
            : 'bg-white border border-gray-200 hover:shadow-lg transition-shadow'
      }`}>
        {plan.highlighted && (
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-yellow-400 text-yellow-900 text-xs font-bold px-3 py-1 rounded-full">
            Recommandé
          </span>
        )}

        <p class={`font-semibold text-sm uppercase tracking-wider mb-2 ${plan.highlighted ? 'text-white/70' : isDark ? 'text-white/60' : 'text-gray-500'}`}>
          {plan.name}
        </p>

        <div class="flex items-baseline gap-1 mb-2">
          <span class={`text-4xl font-extrabold ${plan.highlighted ? 'text-white' : isDark ? 'text-white' : 'text-gray-900'}`}>
            {plan.price}
          </span>
          {plan.period && (
            <span class={`text-sm ${plan.highlighted ? 'text-white/60' : isDark ? 'text-white/50' : 'text-gray-400'}`}>
              /{plan.period}
            </span>
          )}
        </div>

        {plan.description && (
          <p class={`text-sm mb-6 ${plan.highlighted ? 'text-white/70' : isDark ? 'text-white/60' : 'text-gray-500'}`}>
            {plan.description}
          </p>
        )}

        <ul class="space-y-3 mb-8 flex-1">
          {plan.features.map((feature: string) => (
            <li class="flex items-start gap-2.5">
              <svg class={`w-4 h-4 mt-0.5 shrink-0 ${plan.highlighted ? 'text-white' : 'text-[var(--color-brand,#2563eb)]'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class={`text-sm ${plan.highlighted ? 'text-white/90' : isDark ? 'text-white/70' : 'text-gray-600'}`}>{feature}</span>
            </li>
          ))}
        </ul>

        <a
          href={plan.cta.href}
          class={`block text-center px-6 py-3 rounded-xl font-semibold text-sm transition-colors ${
            plan.highlighted
              ? 'bg-white text-[var(--color-brand,#2563eb)] hover:bg-gray-50'
              : isDark
                ? 'bg-white/10 text-white hover:bg-white/20 border border-white/20'
                : 'bg-gray-900 text-white hover:bg-gray-700'
          }`}
        >
          {plan.cta.label}
        </a>
      </div>
    ))}
  </div>
</SectionWrapper>
