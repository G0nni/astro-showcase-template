---
import type { CtaBlock, SectionStyle } from '../../types/site';
import SectionWrapper from './SectionWrapper.astro';

type Props = CtaBlock['props'] & { style?: SectionStyle };

const { title, subtitle, cta, style } = Astro.props;

const effectiveStyle: SectionStyle = { background: 'dark', ...style };
const isDark = ['dark', 'primary', 'gradient'].includes(effectiveStyle.background ?? 'dark');
const isLeft = effectiveStyle.align === 'left';
const subtitleClass = isDark ? 'text-gray-400' : 'text-gray-500';
const btnClass = isDark
  ? 'bg-white text-gray-900 hover:bg-gray-100'
  : 'bg-gray-900 text-white hover:bg-gray-700';
const wrapperClass = isLeft ? 'max-w-3xl' : 'max-w-3xl mx-auto text-center';
---

<SectionWrapper style={effectiveStyle}>
  <div class={wrapperClass}>
    <h2 class="text-3xl md:text-4xl font-bold mb-4">
      {title}
    </h2>
    <p class={`${subtitleClass} text-lg leading-relaxed mb-10`}>
      {subtitle}
    </p>
    <a
      href={cta.href}
      class={`inline-flex items-center justify-center px-7 py-3.5 ${btnClass} font-semibold rounded-xl transition-colors text-sm`}
    >
      {cta.label}
    </a>
  </div>
</SectionWrapper>
