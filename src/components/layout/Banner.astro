---
import type { SiteConfig } from '../../types/site';

interface Props {
  banner: NonNullable<SiteConfig['global']['banner']>;
}
const { banner } = Astro.props;
---

<div id="site-banner" class="bg-[var(--color-brand,#2563eb)] text-white text-sm px-4 py-2.5 flex items-center justify-center gap-3">
  <span>
    {banner.text}
    {banner.link && (
      <a href={banner.link.href} class="underline underline-offset-2 font-semibold hover:no-underline ml-1">
        {banner.link.label} →
      </a>
    )}
  </span>
  {banner.closeable && (
    <button
      class="ml-auto p-1 rounded hover:bg-white/20 transition-colors shrink-0"
      aria-label="Fermer"
      onclick="document.getElementById('site-banner').remove()"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  )}
</div>
