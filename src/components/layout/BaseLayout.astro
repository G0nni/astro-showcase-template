---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import "../../styles/global.css";
import { siteConfig } from "../../config/site";

const { seo, global } = siteConfig;

const {
  title,
  description,
  image = "/images/og.jpg",
  pathname = ""
} = Astro.props;

const finalTitle = title
  ? `${title} | ${global.name}`
  : seo.defaultTitle;

const finalDescription = description || seo.defaultDescription;
const url = global.url + pathname;

const radiusMap: Record<string, string> = {
  none: '0',
  sm: '4px',
  md: '8px',
  lg: '16px',
  full: '9999px',
};
const radiusCard = radiusMap[global.roundedCards ?? 'lg'] ?? '16px';
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- BASIC SEO -->
    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />

    <!-- CANONICAL -->
    <link rel="canonical" href={url} />

    <!-- FAVICON -->
    <link rel="icon" href="/favicon.svg" />

    <!-- CSS VARIABLES -->
    <style set:html={`:root{--color-brand:${global.brandColor ?? '#2563eb'};--radius-card:${radiusCard}}`}></style>

    <!-- GOOGLE FONT -->
    {global.font && (
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link href={`https://fonts.googleapis.com/css2?family=${global.font.replace(/ /g,'+')}:wght@400;500;600;700&display=swap`} rel="stylesheet" />
    )}

    <!-- OPEN GRAPH -->
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={global.url + image} />

    <!-- TWITTER -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={global.url + image} />
  </head>

  <body class="bg-white text-gray-900 antialiased" style={global.font ? `font-family:'${global.font}',system-ui,sans-serif` : ''}>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />

    <!-- INTERSECTION OBSERVER for animation: 'fade' -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll('[data-animate="fade"]').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
