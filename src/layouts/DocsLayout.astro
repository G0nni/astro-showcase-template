---
import '../styles/global.css';
import { siteConfig } from '../config/site';

const brandColor = siteConfig.global.brandColor ?? '#2563eb';
const radiusMap: Record<string, string> = { none: '0', sm: '4px', md: '8px', lg: '16px', full: '9999px' };
const radiusCard = radiusMap[siteConfig.global.roundedCards ?? 'lg'] ?? '16px';

interface NavItem {
  label: string;
  href: string;
  code?: boolean;
}
interface NavGroup {
  title: string;
  items: NavItem[];
}
interface Props {
  title?: string;
  nav: NavGroup[];
}

const { title = 'Documentation', nav } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title} — Astro Showcase Template</title>
  <link rel="icon" href="/favicon.svg" />
  <style set:html={`:root{--color-brand:${brandColor};--radius-card:${radiusCard}}`}></style>
  {siteConfig.global.font && (
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={`https://fonts.googleapis.com/css2?family=${siteConfig.global.font.replace(/ /g,'+')}:wght@400;500;600;700&display=swap`} rel="stylesheet" />
  )}
</head>
<body class="bg-white text-gray-900 antialiased" style={siteConfig.global.font ? `font-family:'${siteConfig.global.font}',system-ui,sans-serif` : ''}>

  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-50 h-14 flex items-center border-b border-gray-100 bg-white/95 backdrop-blur-md px-4 gap-3">
    <button
      id="sidebar-toggle"
      class="lg:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors"
      aria-label="Menu"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <div class="flex items-center gap-2">
      <span class="font-bold text-sm text-gray-900">Astro Showcase Template</span>
      <span class="hidden sm:inline text-gray-300">/</span>
      <span class="hidden sm:inline text-sm text-gray-500">docs</span>
    </div>

    <div class="ml-auto flex items-center gap-4">
      <a
        href="https://github.com/G0nni/astro-showcase-template"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900 transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
        <span class="hidden sm:inline">GitHub</span>
      </a>
    </div>
  </header>

  <div class="flex pt-14 min-h-screen">

    <!-- Sidebar backdrop (mobile) -->
    <div
      id="sidebar-backdrop"
      class="hidden fixed inset-0 z-30 bg-black/20 lg:hidden"
    ></div>

    <!-- Sidebar -->
    <aside
      id="docs-sidebar"
      class="fixed top-14 left-0 z-40 w-64 h-[calc(100vh-3.5rem)] overflow-y-auto border-r border-gray-100 bg-white transition-transform duration-200 -translate-x-full lg:translate-x-0 px-5 py-6"
    >
      <nav>
        {nav.map(group => (
          <div class="mb-7">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 px-2">
              {group.title}
            </p>
            <ul class="space-y-0.5">
              {group.items.map(item => (
                <li>
                  <a
                    href={item.href}
                    class="flex items-center text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-md px-2 py-1.5 transition-colors"
                  >
                    {item.code
                      ? <code class="font-mono text-xs text-blue-600">{item.label}</code>
                      : item.label
                    }
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <!-- Main content -->
    <main class="lg:ml-64 min-w-0 flex-1">
      <slot />
    </main>

  </div>

  <script>
    const sidebar = document.getElementById('docs-sidebar');
    const backdrop = document.getElementById('sidebar-backdrop');
    const toggle = document.getElementById('sidebar-toggle');

    function openSidebar() {
      sidebar?.classList.remove('-translate-x-full');
      backdrop?.classList.remove('hidden');
    }
    function closeSidebar() {
      sidebar?.classList.add('-translate-x-full');
      backdrop?.classList.add('hidden');
    }

    toggle?.addEventListener('click', () => {
      sidebar?.classList.contains('-translate-x-full') ? openSidebar() : closeSidebar();
    });
    backdrop?.addEventListener('click', closeSidebar);

    // Close sidebar when clicking a link on mobile
    sidebar?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth < 1024) closeSidebar();
      });
    });
  </script>

</body>
</html>
