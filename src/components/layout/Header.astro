---
import { siteConfig } from '../../config/site';

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">

    <a href={base + '/'} class="font-bold text-lg text-gray-900 tracking-tight">
      {siteConfig.global.name}
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {siteConfig.navigation.map((item) => (
        <a
          href={base + item.href}
          class={`text-sm font-medium transition-colors ${
            currentPath === base + item.href
              ? 'text-gray-900'
              : 'text-gray-500 hover:text-gray-900'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <button
      class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors"
      aria-label="Ouvrir le menu"
      onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4">
      {siteConfig.navigation.map((item) => (
        <a href={base + item.href} class="text-sm font-medium text-gray-700 hover:text-gray-900">
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
