---
import type { GalleryBlock, SectionStyle } from '../../types/site';
import SectionWrapper from './SectionWrapper.astro';

type Props = GalleryBlock['props'] & { style?: SectionStyle };

const { title, items, columns = 3, style } = Astro.props;

const isDark = style?.background && ['dark', 'primary', 'gradient'].includes(style.background);
const headingClass  = isDark ? 'text-white' : 'text-gray-900';
const captionClass  = isDark ? 'text-white/60' : 'text-gray-400';
const gridCols = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 md:grid-cols-3',
  4: 'grid-cols-2 md:grid-cols-4',
}[columns] ?? 'grid-cols-2 md:grid-cols-3';
---

<SectionWrapper style={style}>
  {title && (
    <h2 class={`text-3xl md:text-4xl font-bold text-center ${headingClass} mb-12`}>{title}</h2>
  )}

  <div class={`grid ${gridCols} gap-4`}>
    {items.map((item: import('../../types/site').GalleryItem) => (
      <div class="group relative overflow-hidden rounded-card aspect-square">
        <img
          src={item.imageUrl}
          alt={item.alt}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
        {item.caption && (
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors duration-200 flex items-end">
            <p class={`w-full px-3 py-2 text-sm text-white font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-200 ${captionClass}`}>
              {item.caption}
            </p>
          </div>
        )}
      </div>
    ))}
  </div>
</SectionWrapper>
