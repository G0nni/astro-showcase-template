---
import type { MapBlock, SectionStyle } from '../../types/site';
import SectionWrapper from './SectionWrapper.astro';

type Props = MapBlock['props'] & { style?: SectionStyle };

const { title, embedUrl, height = 'md', address, addressLink, style } = Astro.props;

const isDark = style?.background && ['dark', 'primary', 'gradient'].includes(style.background);
const headingClass  = isDark ? 'text-white' : 'text-gray-900';
const addressClass  = isDark ? 'text-white/70' : 'text-gray-500';

const heightMap: Record<string, string> = {
  sm: 'h-48',
  md: 'h-72',
  lg: 'h-96',
};
const iframeHeight = heightMap[height] ?? 'h-72';
---

<SectionWrapper style={style}>
  {title && (
    <h2 class={`text-2xl md:text-3xl font-bold ${headingClass} mb-8`}>{title}</h2>
  )}

  <div class={`w-full ${iframeHeight} rounded-card overflow-hidden shadow-lg`}>
    <iframe
      src={embedUrl}
      class="w-full h-full border-0"
      loading="lazy"
      title={title ?? 'Carte'}
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen
    ></iframe>
  </div>

  {address && (
    <div class={`mt-4 flex items-center gap-2 justify-center ${addressClass}`}>
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      {addressLink ? (
        <a href={addressLink} target="_blank" rel="noopener" class="text-sm hover:underline">{address}</a>
      ) : (
        <span class="text-sm">{address}</span>
      )}
    </div>
  )}
</SectionWrapper>
