---
import type {
  SectionBlock,
  HeroBlock, FeaturesBlock, CtaBlock, TextBlock, ContactInfoBlock,
  StatsBlock, TestimonialsBlock, ImageTextBlock, FaqBlock, LogosBlock,
  PricingBlock, StepsBlock, TeamBlock, TimelineBlock, VideoBlock, GalleryBlock, NewsletterBlock,
  ComparisonBlock, DownloadBlock, MapBlock, ReviewsBlock,
} from '../types/site';
import Hero         from './sections/Hero.astro';
import Features     from './sections/Features.astro';
import CTA          from './sections/CTA.astro';
import TextSection  from './sections/TextSection.astro';
import ContactInfo  from './sections/ContactInfo.astro';
import Stats        from './sections/Stats.astro';
import Testimonials from './sections/Testimonials.astro';
import ImageText    from './sections/ImageText.astro';
import FAQ          from './sections/FAQ.astro';
import Logos        from './sections/Logos.astro';
import Pricing      from './sections/Pricing.astro';
import Steps        from './sections/Steps.astro';
import Team         from './sections/Team.astro';
import Timeline     from './sections/Timeline.astro';
import Video        from './sections/Video.astro';
import Gallery      from './sections/Gallery.astro';
import Newsletter   from './sections/Newsletter.astro';
import Comparison   from './sections/Comparison.astro';
import Download     from './sections/Download.astro';
import Map          from './sections/Map.astro';
import Reviews      from './sections/Reviews.astro';

interface Props {
  block: SectionBlock;
}

const { block } = Astro.props;
---

{block.type === 'hero'         && <Hero         {...(block as HeroBlock).props}         style={(block as HeroBlock).style} />}
{block.type === 'features'     && <Features     {...(block as FeaturesBlock).props}     style={(block as FeaturesBlock).style} />}
{block.type === 'cta'          && <CTA          {...(block as CtaBlock).props}          style={(block as CtaBlock).style} />}
{block.type === 'text'         && <TextSection  {...(block as TextBlock).props}         style={(block as TextBlock).style} />}
{block.type === 'contactInfo'  && <ContactInfo  {...(block as ContactInfoBlock).props}  style={(block as ContactInfoBlock).style} />}
{block.type === 'stats'        && <Stats        {...(block as StatsBlock).props}        style={(block as StatsBlock).style} />}
{block.type === 'testimonials' && <Testimonials {...(block as TestimonialsBlock).props} style={(block as TestimonialsBlock).style} />}
{block.type === 'imageText'    && <ImageText    {...(block as ImageTextBlock).props}    style={(block as ImageTextBlock).style} />}
{block.type === 'faq'          && <FAQ          {...(block as FaqBlock).props}          style={(block as FaqBlock).style} />}
{block.type === 'logos'        && <Logos        {...(block as LogosBlock).props}        style={(block as LogosBlock).style} />}
{block.type === 'pricing'      && <Pricing      {...(block as PricingBlock).props}      style={(block as PricingBlock).style} />}
{block.type === 'steps'        && <Steps        {...(block as StepsBlock).props}        style={(block as StepsBlock).style} />}
{block.type === 'team'         && <Team         {...(block as TeamBlock).props}         style={(block as TeamBlock).style} />}
{block.type === 'timeline'     && <Timeline     {...(block as TimelineBlock).props}     style={(block as TimelineBlock).style} />}
{block.type === 'video'        && <Video        {...(block as VideoBlock).props}        style={(block as VideoBlock).style} />}
{block.type === 'gallery'      && <Gallery      {...(block as GalleryBlock).props}      style={(block as GalleryBlock).style} />}
{block.type === 'newsletter'   && <Newsletter   {...(block as NewsletterBlock).props}   style={(block as NewsletterBlock).style} />}
{block.type === 'comparison'   && <Comparison   {...(block as ComparisonBlock).props}   style={(block as ComparisonBlock).style} />}
{block.type === 'download'     && <Download     {...(block as DownloadBlock).props}     style={(block as DownloadBlock).style} />}
{block.type === 'map'          && <Map          {...(block as MapBlock).props}          style={(block as MapBlock).style} />}
{block.type === 'reviews'      && <Reviews      {...(block as ReviewsBlock).props}      style={(block as ReviewsBlock).style} />}
