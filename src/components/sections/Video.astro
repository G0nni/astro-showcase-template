---
import type { VideoBlock, SectionStyle } from '../../types/site';
import SectionWrapper from './SectionWrapper.astro';

type Props = VideoBlock['props'] & { style?: SectionStyle };

const { title, videoUrl, caption, style } = Astro.props;

const isDark = style?.background && ['dark', 'primary', 'gradient'].includes(style.background);
const headingClass = isDark ? 'text-white' : 'text-gray-900';
const captionClass = isDark ? 'text-white/50' : 'text-gray-400';
---

<SectionWrapper style={style}>
  {title && (
    <h2 class={`text-3xl md:text-4xl font-bold text-center ${headingClass} mb-10`}>{title}</h2>
  )}

  <div class="max-w-3xl mx-auto">
    <div class="relative w-full aspect-video rounded-card overflow-hidden shadow-xl">
      <iframe
        src={videoUrl}
        title={title ?? 'Vidéo'}
        class="absolute inset-0 w-full h-full"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
    {caption && (
      <p class={`text-center text-sm mt-4 ${captionClass}`}>{caption}</p>
    )}
  </div>
</SectionWrapper>
